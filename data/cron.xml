<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_service_request_deadline_reminder" model="ir.cron">
        <field name="name">Service Request: Deadline Reminder</field>
        <field name="model_id" ref="model_service_request"/>
        <field name="state">code</field>
        <field name="code">model.action_send_deadline_reminder()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="active" eval="True"/>
    </record>
</odoo>
