<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Rule: User sees only their own records -->
    <record id="rule_service_request_user" model="ir.rule">
        <field name="name">Service Request: See Own Records Only</field>
        <field name="model_id" ref="model_service_request"/>
        <field name="groups" eval="[(4, ref('group_service_request_user'))]"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Rule: Manager sees all records -->
    <record id="rule_service_request_manager" model="ir.rule">
        <field name="name">Service Request: See All Records</field>
        <field name="model_id" ref="model_service_request"/>
        <field name="groups" eval="[(4, ref('group_service_request_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
