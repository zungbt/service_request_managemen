    <!-- Sales Order Views -->
    <record id="view_laptop_sale_tree" model="ir.ui.view">
        <field name="name">laptop.sale.tree</field>
        <field name="model">laptop.sale</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'draft'" decoration-success="state == 'confirmed'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="date_order"/>
                <field name="amount_total" sum="Total Amount"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'confirmed'"/>
            </tree>
        </field>
    </record>

    <record id="view_laptop_sale_form" model="ir.ui.view">
        <field name="name">laptop.sale.form</field>
        <field name="model">laptop.sale</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state not in ['draft', 'confirmed']"/>
                    <button name="action_draft" string="Set to Draft" type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" placeholder="Select Customer..." readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="date_order" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Laptop Lines" name="laptop_lines">
                            <field name="sale_line_ids" readonly="state != 'draft'">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="amount_total" class="oe_subtotal_footer_separator"/>
                                <field name="margin_total" widget="monetary" string="Tổng lợi nhuận"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

