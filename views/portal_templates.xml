<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template mới cho trang /service/requests -->
    <template id="portal_my_service_requests" name="My Service Requests">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Service Requests</t>
            </t>
            
            <t t-if="not requests">
                <div class="alert alert-warning mt8" role="alert">
                    There are no service requests.
                </div>
            </t>
            <t t-if="requests">
                <table class="table rounded mb-0 bg-white o_portal_my_doc_table">
                    <thead>
                        <tr class="active">
                            <th>Request #</th>
                            <th>Request Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="requests" t-as="req">
                            <tr>
                                <td><span t-field="req.name"/></td>
                                <td><span t-field="req.request_date"/></td>
                                <td>
                                    <span class="badge rounded-pill text-bg-info" t-if="req.state == 'draft'"><i class="fa fa-fw fa-clock-o" aria-label="Draft" title="Draft" role="img"></i><span class="d-none d-md-inline"> Draft</span></span>
                                    <span class="badge rounded-pill text-bg-primary" t-if="req.state == 'submitted'"><i class="fa fa-fw fa-check" aria-label="Submitted" title="Submitted" role="img"></i><span class="d-none d-md-inline"> Submitted</span></span>
                                    <span class="badge rounded-pill text-bg-success" t-if="req.state == 'approved'"><i class="fa fa-fw fa-check" aria-label="Approved" title="Approved" role="img"></i><span class="d-none d-md-inline"> Approved</span></span>
                                    <span class="badge rounded-pill text-bg-success" t-if="req.state == 'done'"><i class="fa fa-fw fa-check" aria-label="Done" title="Done" role="img"></i><span class="d-none d-md-inline"> Done</span></span>
                                    <span class="badge rounded-pill text-bg-danger" t-if="req.state == 'cancelled'"><i class="fa fa-fw fa-times" aria-label="Cancelled" title="Cancelled" role="img"></i><span class="d-none d-md-inline"> Cancelled</span></span>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </t>
        </t>
    </template>

    <!-- Inherit template portal.portal_my_home để thêm mục Service Requests vào My Account -->
    <template id="portal_my_home_inherit_service_requests" name="Show Service Requests in Portal" inherit_id="portal.portal_my_home" priority="40">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Service Requests</t>
                <t t-set="url" t-value="'/service/requests'"/>
                <t t-set="placeholder_count" t-value="'request_count'"/>
            </t>
        </xpath>
    </template>
</odoo>
