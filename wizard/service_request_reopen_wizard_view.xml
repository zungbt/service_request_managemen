<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_service_request_reopen_wizard_form" model="ir.ui.view">
        <field name="name">service.request.reopen.wizard.form</field>
        <field name="model">service.request.reopen.wizard</field>
        <field name="arch" type="xml">
            <form string="Reopen Service Request">
                <group>
                    <field name="request_id" invisible="1"/>
                    <field name="reason" placeholder="Enter reason for reopening..."/>
                </group>
                <footer>
                    <button name="action_confirm_reopen" string="Confirm Reopen" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_service_request_reopen_wizard" model="ir.actions.act_window">
        <field name="name">Reopen Service Request</field>
        <field name="res_model">service.request.reopen.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
